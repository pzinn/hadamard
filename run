#!/bin/bash

# Create logs directory if it doesn't exist
mkdir -p logs

# Generate timestamp
timestamp=$(date +%Y-%m-%d-%H-%M-%S)
logfile="nohup-${timestamp}.out"

# Run program in background and redirect output
nohup python hadamard.py > "logs/$logfile" 2>&1 &

# Update symlink
ln -sf "$logfile" logs/latest.out
